{
  "name": "omni-ai-chat",
  "version": "1.0.0",
  "description": "Multi-platform desktop client integrating multiple AI chats with global broadcast.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:all": "electron-builder --win --mac"
  },
  "devDependencies": {
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.omniaichat.app",
    "productName": "OmniAIChat",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "assets/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "category": "public.app-category.productivity"
    },
    "files": [
      "main.js",
      "index.html",
      "style.css",
      "renderer.js",
      "injection-script.js",
      "assets/**/*",
      "package.json"
    ]
  }
}
